# Copy to .env.local and fill in real values. Never commit .env.local.
# Get Supabase keys from https://supabase.com/dashboard/project/edkeagxgdpyzhrhkwcqs/settings/api

# Public anon key (safe to expose to the browser — RLS does the real protection)
NEXT_PUBLIC_SUPABASE_URL=https://edkeagxgdpyzhrhkwcqs.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# Service role key (bypasses RLS — NEVER expose to the browser).
# Only used in server-only code (server actions, API routes, cron jobs).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# Production site URL — used in notification email links
NEXT_PUBLIC_SITE_URL=https://upcbma.com

# Transactional email via Resend (https://resend.com)
RESEND_API_KEY=re_...
EMAIL_FROM=UPCBMA <noreply@upcbma.com>
EMAIL_REPLY_TO=

# Optional — only for scripts/apply-permissions-rls.mjs
# SUPABASE_ACCESS_TOKEN=sbp_...
